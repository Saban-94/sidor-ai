rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['date', 'time', 'driverId', 'customerName', 'destination', 'items', 'warehouse', 'status', 'createdAt', 'updatedAt', 'createdBy'])
        && data.keys().size() == 11
        && data.date is string && data.date.size() <= 10
        && data.time is string && data.time.size() <= 6
        && data.driverId is string && data.driverId.size() <= 100
        && data.customerName is string && data.customerName.size() <= 200
        && data.destination is string && data.destination.size() <= 500
        && data.items is string && data.items.size() <= 1000
        && data.warehouse in ['החרש', 'התלמיד']
        && data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.createdBy == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn(); // All staff can read orders
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isEmailVerified() && isValidOrder(request.resource.data) 
        && request.resource.data.updatedAt == request.time
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          // Allow full update by owner
          isOwner(resource.data)
          // or specific status updates by any verified staff
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
        );
      allow delete: if isEmailVerified() && isOwner(resource.data);
    }

    // --- Inventory Rules Validation ---
    function isValidInventoryRule(data) {
      return data.keys().hasAll(['itemName'])
        && data.itemName is string && data.itemName.size() <= 200;
    }

    match /inventoryRules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if isEmailVerified(); // Keep it simple for rules management
    }
  }
}
