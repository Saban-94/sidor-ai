rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      let requiredFields = ['date', 'time', 'driverId', 'customerName', 'destination', 'items', 'warehouse', 'status', 'createdAt', 'updatedAt', 'createdBy'];
      return data.keys().hasAll(requiredFields)
        && data.date is string && data.date.size() <= 10
        && data.time is string && data.time.size() <= 6
        && data.driverId is string && data.driverId.size() <= 100
        && data.customerName is string && data.customerName.size() <= 200
        && data.destination is string && data.destination.size() <= 500
        && data.items is string && data.items.size() <= 2000
        && data.warehouse in ['החרש', 'התלמיד']
        && data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.createdBy is string
        && (!data.keys().contains('orderNumber') || data.orderNumber is string)
        && (!data.keys().contains('trackingId') || (data.trackingId is string && data.trackingId.size() <= 20))
        && (!data.keys().contains('customerId') || (data.customerId is string || data.customerId == null))
        && (!data.keys().contains('customerPhone') || data.customerPhone is string)
        && (!data.keys().contains('totalAmount') || data.totalAmount is number)
        && (!data.keys().contains('eta') || data.eta is string);
    }

    match /orders/{orderId} {
      allow read: if isSignedIn(); 
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(request.resource.data) && request.resource.data.createdBy == request.auth.uid && request.resource.data.createdAt == request.time;
      allow update: if isEmailVerified() && isValidOrder(request.resource.data) 
        && request.resource.data.updatedAt == request.time
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          isOwner(resource.data)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'eta', 'updatedAt']))
        );
      allow delete: if isEmailVerified() && isOwner(resource.data);
    }

    // --- Morning Report Validation ---
    function isValidMorningReport(data) {
      return data.keys().hasAll(['date', 'orderIds', 'reportText', 'createdAt'])
        && data.date is string
        && data.orderIds is list
        && data.reportText is string
        && data.createdAt is timestamp;
    }

    match /morning_reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidMorningReport(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update, delete: if isEmailVerified() && isAdmin(); // Or keep restricted
    }

    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.keys().contains('email') &&
        (request.auth.token.email.lower() == 'hsaban2025@gmail.com' ||
         request.auth.token.email == 'hsaban2025@gmail.com');
    }

    // --- Inventory Rules Validation ---
    function isValidInventoryRule(data) {
      return data.keys().hasAll(['itemName'])
        && data.itemName is string && data.itemName.size() <= 200;
    }

    match /inventoryRules/{ruleId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isEmailVerified()) && isValidInventoryRule(request.resource.data);
      allow delete: if isSignedIn() && (isAdmin() || isEmailVerified());
    }

    // --- Driver Validation ---
    function isValidDriver(data) {
      return data.keys().hasAll(['name'])
        && data.name is string
        && (!data.keys().contains('phone') || data.phone is string)
        && (!data.keys().contains('vehicleType') || data.vehicleType in ['crane', 'truck'])
        && (!data.keys().contains('totalDeliveries') || data.totalDeliveries is number)
        && (!data.keys().contains('onTimeRate') || data.onTimeRate is number)
        && (!data.keys().contains('rating') || data.rating is number);
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isEmailVerified()) && isValidDriver(request.resource.data);
      allow delete: if isSignedIn() && (isAdmin() || isEmailVerified());
    }

    // --- Customer Validation ---
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'customerNumber'])
        && data.name is string
        && data.customerNumber is string
        && (!data.keys().contains('phone') || data.phone is string)
        && (!data.keys().contains('phoneNumber') || data.phoneNumber is string)
        && (!data.keys().contains('address') || data.address is string)
        && (!data.keys().contains('totalOrders') || data.totalOrders is number)
        && (!data.keys().contains('lastOrderAt') || data.lastOrderAt is timestamp)
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp)
        && (!data.keys().contains('createdAt') || data.createdAt is timestamp);
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isEmailVerified()) && isValidCustomer(request.resource.data);
      allow delete: if isSignedIn() && (isAdmin() || isEmailVerified());
    }

    // --- Reminder Validation ---
    function isValidReminder(data) {
      return data.keys().hasAll(['title', 'dueDate', 'dueTime'])
        && data.title is string
        && data.dueDate is string
        && data.dueTime is string;
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isEmailVerified()) && isValidReminder(request.resource.data);
      allow delete: if isSignedIn() && (isAdmin() || isEmailVerified());
    }

    // --- Inventory Item Validation ---
    function isValidInventoryItem(data) {
      return data.keys().hasAll(['sku', 'name', 'unit', 'currentStock'])
        && data.sku is string && data.sku.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.unit is string && data.unit.size() <= 50
        && data.currentStock is number
        && (!data.keys().contains('description') || data.description is string)
        && (!data.keys().contains('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && (!data.keys().contains('minStock') || data.minStock is number)
        && (!data.keys().contains('price') || data.price is number)
        && (!data.keys().contains('category') || data.category is string)
        && (!data.keys().contains('createdAt') || data.createdAt is timestamp)
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp);
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isEmailVerified() && isValidInventoryItem(request.resource.data);
      allow delete: if isEmailVerified();
    }

    // --- Sale Record Validation ---
    function isValidSaleRecord(data) {
      return data.keys().hasAll(['itemId', 'customerName', 'quantity', 'date'])
        && data.itemId is string && data.itemId.size() <= 100
        && data.customerName is string && data.customerName.size() <= 200
        && data.quantity is number
        && data.date is string && data.date.size() <= 20
        && (!data.keys().contains('itemName') || data.itemName is string)
        && (!data.keys().contains('orderId') || data.orderId is string)
        && (!data.keys().contains('priceAtSale') || data.priceAtSale is number)
        && (!data.keys().contains('createdAt') || data.createdAt is timestamp);
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidSaleRecord(request.resource.data);
      allow update, delete: if isEmailVerified();
    }

    // --- Chat History ---
    match /users/{userId}/messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
