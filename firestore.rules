rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Magic Pages ---
    match /user_magic_pages/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create, update: if isSignedIn() && (
        incoming().keys().hasAll(['id', 'name', 'role']) &&
        incoming().name is string && incoming().name.size() < 100 &&
        incoming().role is string && incoming().role.size() < 100 &&
        incoming().id == userId
      );
      allow delete: if isSignedIn();
    }

    // --- Internal Team Chats (Office Messages) ---
    match /office_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isValidId(incoming().senderId) &&
        incoming().text is string && incoming().text.size() < 2000 &&
        incoming().timestamp == request.time
      );
      allow update, delete: if false; 
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        incoming().customerName is string &&
        incoming().items is string
      );
    }
    
    // --- Reminders ---
    match /reminders/{reminderId} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (incoming().userId == request.auth.uid)
      );
    }

    // --- Inventory ---
    match /inventory/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Drivers ---
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Customers ---
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Morning Reports ---
    match /morning_reports/{reportId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Private Chats (Individual) ---
    match /users/{userId}/messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
