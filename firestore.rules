rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Magic Pages ---
    function isValidUserProfile(data) {
      return data.id is string && data.id.size() <= 10 &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role.size() <= 100;
    }

    match /user_magic_pages/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidUserProfile(incoming());
      
      allow update: if isSignedIn() && (
        // Action: Update Profile (Requires all fields)
        (isValidUserProfile(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['id', 'name', 'role', 'phone', 'email', 'avatarUrl', 'updatedAt', 'lastSeen'])) ||
        // Action: Heartbeat (Only lastSeen)
        (incoming().diff(existing()).affectedKeys().hasOnly(['lastSeen']))
      );
      
      allow delete: if isSignedIn();
    }

    // --- Internal Team Chats (Office Messages) ---
    function isValidMessage(data) {
      return data.senderId is string && data.senderId.size() <= 128 &&
             data.text is string && data.text.size() <= 2000;
    }

    match /office_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming()) && (
        incoming().timestamp == request.time
      );
      allow update, delete: if false; 
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        incoming().customerName is string &&
        incoming().items is string
      );
    }
    
    // --- Reminders ---
    match /reminders/{reminderId} {
      allow read, write: if isSignedIn() && (
        (resource == null || resource.data.userId == request.auth.uid) &&
        (incoming().userId == request.auth.uid)
      );
    }

    // --- Inventory ---
    match /inventory/{itemId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Drivers ---
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Customers ---
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Morning Reports ---
    match /morning_reports/{reportId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Private Chats (Individual) ---
    match /users/{userId}/messages/{messageId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
